# =============================================================================
# Keys needed for integrations (copy to .env and fill)
# =============================================================================
# Get keys from:
#   - Aviation Stack: https://aviationstack.com/ (sign up → dashboard)
#   - Google Cloud:   https://console.cloud.google.com/ (APIs & Services → Credentials)
# =============================================================================

# Flight tracking – POST /flights/track (free tier: 100 req/month)
# https://aviationstack.com/signup/free
AVIATION_STACK_API_KEY=

# Geocoding & Places – optional; for building google_maps_url in itineraries
# Enable Geocoding API + Places API, create API key, restrict for backend
# https://developers.google.com/maps/documentation/geocoding
# https://developers.google.com/maps/documentation/places
GOOGLE_MAPS_API_KEY=

# =============================================================================
# Optional
# =============================================================================

# Ollama model override (default: llama3.2)
# OLLAMA_MODEL=llama3.1:8b

# Ollama timeout in seconds (default: 300). Generation can take 6+ minutes; use 600 (10 min) or more for safety.
# OLLAMA_TIMEOUT_SEC=2000

# CORS origins, comma-separated
# CORS_ORIGINS=https://your-frontend.netlify.app

# Destinations from Hugging Face DeepNLP/travel-ai-agent (requires: pip install datasets)
# https://huggingface.co/datasets/DeepNLP/travel-ai-agent
# DESTINATIONS_USE_HF=1
